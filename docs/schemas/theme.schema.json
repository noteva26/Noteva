{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noteva.org/schemas/theme.schema.json",
  "title": "Noteva Theme Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "name",
    "short",
    "description",
    "version",
    "author",
    "repository",
    "requires"
  ],
  "properties": {
    "schema": {
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "short": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "repository": {
      "type": "string",
      "oneOf": [
        {
          "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+(?:\\.git)?/?$"
        },
        {
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        }
      ]
    },
    "preview": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.)[A-Za-z0-9._/-]+$"
    },
    "requires": {
      "type": "object",
      "additionalProperties": false,
      "required": ["noteva"],
      "properties": {
        "noteva": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "title"],
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{0,95}$"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          }
        }
      }
    },
    "configuration": {
      "type": "object"
    },
    "i18n": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locales", "default"],
      "properties": {
        "locales": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]{1,20}$"
          }
        },
        "default": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,20}$"
        }
      }
    }
  }
}
