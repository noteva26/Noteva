{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noteva.org/schemas/theme-settings.schema.json",
  "title": "Noteva Theme Settings",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "sections"],
  "properties": {
    "schema": {
      "const": 1
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/section"
      }
    }
  },
  "$defs": {
    "localizedText": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string"
          }
        }
      ]
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "fields"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{0,63}$"
        },
        "title": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "label"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{0,63}$"
        },
        "type": {
          "enum": ["text", "textarea", "switch", "select", "number", "color", "array"]
        },
        "label": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "placeholder": {
          "$ref": "#/$defs/localizedText"
        },
        "default": true,
        "required": {
          "type": "boolean"
        },
        "secret": {
          "type": "boolean"
        },
        "rows": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        },
        "maxLength": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/selectOption"
          }
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "step": {
          "type": "number"
        },
        "itemFields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/arrayItemField"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "select"
              }
            }
          },
          "then": {
            "required": ["options"]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "array"
              }
            }
          },
          "then": {
            "required": ["itemFields"]
          }
        }
      ]
    },
    "selectOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "label"],
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "$ref": "#/$defs/localizedText"
        }
      }
    },
    "arrayItemField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "type"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{0,63}$"
        },
        "label": {
          "$ref": "#/$defs/localizedText"
        },
        "type": {
          "enum": ["text", "number"]
        },
        "placeholder": {
          "$ref": "#/$defs/localizedText"
        },
        "required": {
          "type": "boolean"
        }
      }
    }
  }
}
